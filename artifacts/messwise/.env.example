# API Configuration
VITE_API_URL=http://localhost:3000/api

# Environment
VITE_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_LEADERBOARD=true
VITE_ENABLE_ADMIN_PANEL=true

# App Configuration
VITE_APP_NAME=MessWise
VITE_APP_VERSION=1.0.0

