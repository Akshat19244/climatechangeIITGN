{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "dev": "pnpm --filter messwise dev",
    "messwise:dev": "pnpm --filter messwise dev",
    "messwise:build": "pnpm --filter messwise build",
    "build": "pnpm --filter messwise build",
    "typecheck:libs": "echo 'Skipping root typecheck'",
    "typecheck": "pnpm --filter messwise typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
